# =============================================================
# 🍲 Tambouille — variables d'environnement (template)
# =============================================================
# Copier ce fichier en `.env.local` (qui est git-ignoré) puis remplir.
# Ne jamais committer `.env.local` ni de vraies clés.
#
# Où trouver ces valeurs ?
#  → Supabase : Project Settings → API (URL + anon + service_role)
#  → Anthropic : console.anthropic.com → API Keys (phase 3 uniquement)
# =============================================================

# --- Client (exposé au navigateur via Next.js) -----------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- Serveur uniquement (ne JAMAIS exposer côté client) -------
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Phase 3 (import URL via Claude) --------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
